{
  "name": "oreum-ui",
  "repository": "https://github.com/oreum-space/oreum-ui",
  "license": "MIT",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "public"
  ],
  "main": "./dist/oreum-ui.umd.cjs",
  "module": "./dist/oreum-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oreum-ui.js",
      "require": "./dist/oreum-ui.umd.cjs"
    },
    "./oreum-ui.css": "./dist/oreum-ui.css",
    "./icons.svg": "./dist/icons.svg"
  },
  "scripts": {
    "lint": "eslint --ext .ts,.vue src",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "nodemon"
  },
  "dependencies": {
    "nodemon": "^3.0.1",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.5.6",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "@vitejs/plugin-vue": "^4.3.4",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/eslint-config-typescript": "^12.0.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "sass": "^1.66.1",
    "typescript": "5.1.3",
    "vite": "^4.4.9",
    "vite-plugin-eslint": "^1.8.1",
    "vue-tsc": "^1.8.11"
  }
}
